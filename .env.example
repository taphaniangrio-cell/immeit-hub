GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
CEREBRAS_API_KEY=...
MISTRAL_API_KEY=...
GITHUB_TOKEN=ghp_...
PEXELS_API_KEY=...
DATABASE_URL=postgres://user:pass@ep-xxx.eu-west-1.aws.neon.tech/neondb
# Note : ADMIN_PASSWORD est déprécié. Préférez PASSWORD_HASH (hash bcrypt)
# Générer avec : node scripts/generate-hash.js <mot-de-passe>
# ADMIN_PASSWORD=changeme
PASSWORD_HASH=
SESSION_SECRET=generer-avec-crypto-randomBytes-32-hex
ALLOWED_ORIGIN=http://localhost:3000,https://articles-immeit.vercel.app

# SharePoint / Microsoft Graph (optionnel — pour le tableau de bord)
# 1. Créer une app dans https://entra.microsoft.com (Azure AD)
# 2. Ajouter permission: Sites.Read.All (application)
# 3. Générer un secret client
# 4. Copier les valeurs ci-dessous
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_HOSTNAME=shiftup.sharepoint.com
SHAREPOINT_SITE_PATH=sites/P2M2022
SHAREPOINT_FILE_ID=55686017-3ff9-43f7-ab28-5b910871a4b0
SHAREPOINT_SHEET_NAME=Suivi Demandes 2026

LOG_LEVEL=info

# Destinataire des alertes email (envoyées via Microsoft Graph API — même auth que SharePoint)
ALERT_EMAIL_TO=moustapha.niang@external.stellantis.com

# ── API KEYS (IA Providers) ──
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
CEREBRAS_API_KEY=...
MISTRAL_API_KEY=...
GITHUB_TOKEN=ghp_...
PEXELS_API_KEY=...

# ── Database (Supabase / tout Postgres compatible) ──
# Supabase : Settings → Database → Connection string → URI
# Format : postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# ── Authentication ──
# Générer le hash : node scripts/generate-hash.js <mot-de-passe>
PASSWORD_HASH=
SESSION_SECRET=generer-avec-crypto-randomBytes-32-hex

# ── CORS ──
ALLOWED_ORIGIN=http://localhost:3000,https://articles-immeit.vercel.app

# ── SharePoint / Microsoft Graph ──
# Par défaut, AUCUNE variable ci-dessous n'est requise : lib/sharepoint.js utilise des
# valeurs par défaut (site/fichier/onglet déjà en usage) et s'authentifie via un compte
# délégué dont le jeton est mis en cache de façon persistante en base de données (voir
# lib/msal-cache-plugin.js). Une seule connexion initiale est nécessaire :
#   node scripts/connect-sharepoint.js
# Elle n'a besoin d'être refaite qu'en cas de révocation de session côté Microsoft 365.
#
# SHAREPOINT_CLIENT_ID / SHAREPOINT_CLIENT_SECRET (optionnel, upgrade) : si vous disposez
# des droits admin Azure AD, créez une App Registration avec la permission Application
# "Sites.Selected" (ou "Sites.Read.All") + consentement admin, puis renseignez ces deux
# variables. Ce mode "app-only" devient alors prioritaire : zéro connexion humaine, même
# pour la toute première fois. Voir scripts/setup-azure-app.mjs pour un assistant de mise
# en place (nécessite des droits admin sur le tenant Azure AD).
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_HOSTNAME=
SHAREPOINT_SITE_PATH=
SHAREPOINT_FILE_ID=
SHAREPOINT_SHEET_NAME=Suivi Demandes 2026
# Client ID du compte délégué pour le device code (défaut : compte Microsoft global)
# SHAREPOINT_DELEGATED_CLIENT_ID=

# ── Cache de secours GitHub (optionnel) ──
# Par défaut : dépôt taphaniangrio-cell/articles-immeit, branche cache. À redéfinir
# uniquement si le dépôt est déplacé/renommé.
GITHUB_CACHE_OWNER=
GITHUB_CACHE_REPO=
GITHUB_CACHE_BRANCH=

# ── CRON / Sync automatisé ──
# Secret partagé entre Vercel et GitHub Actions pour le sync automatique
# À définir aussi dans les secrets GitHub (Settings → Secrets → Actions → CRON_SECRET)
CRON_SECRET=generer-une-chaine-aleatoire

# ── Logging ──
LOG_LEVEL=info

# ── SMTP (email alerts, optionnel) ──
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=IMMEIT Hub <email@domain.com>
ALERT_EMAIL_TO=
